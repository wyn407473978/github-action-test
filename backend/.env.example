# 复制为 .env 文件并填入实际值

# Docker Hub 配置# 复制为 .env 文件并填入实际值
               #
               ## Docker Hub 配置
               #DOCKER_USERNAME=your_docker_username
               #DOCKER_PASSWORD=your_docker_password
               #
               ## 服务器配置
               #SERVER_HOST=your_server_ip
               #SERVER_USER=your_ssh_username
               #SSH_PRIVATE_KEY=your_private_key_content
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# 服务器配置
SERVER_HOST=your_server_ip
SERVER_USER=your_ssh_username
SSH_PRIVATE_KEY=your_private_key_content
